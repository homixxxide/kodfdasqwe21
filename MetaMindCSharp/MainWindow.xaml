<Window x:Class="MetaMind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        Title="MetaMind v6.5"
        Width="1360" Height="860"
        MinWidth="1160" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Ellipse Width="920" Height="920" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-250,-260,0,0" Opacity="0.35">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#80FF3B30" Offset="0"/>
                    <GradientStop Color="#00FF3B30" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <effects:BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="760" Height="760" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-200,-220" Opacity="0.22">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7038D9FF" Offset="0"/>
                    <GradientStop Color="#0038D9FF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <effects:BlurEffect Radius="100"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border Margin="14" CornerRadius="26" BorderThickness="1" BorderBrush="#39FFFFFF" Padding="12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F20B0D10" Offset="0"/>
                    <GradientStop Color="#F2121318" Offset="0.5"/>
                    <GradientStop Color="#F2090A0D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <effects:DropShadowEffect Color="#AA000000" BlurRadius="36" ShadowDepth="10" Opacity="0.8"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="78"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="18" BorderThickness="1" BorderBrush="#4DFF8C86" MouseLeftButtonDown="HeaderDrag">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C1181114" Offset="0"/>
                            <GradientStop Color="#D01A1218" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                            <TextBlock Text="METAMIND" FontFamily="Segoe UI Semibold" FontSize="34" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" v6.5" FontSize="22" FontWeight="Bold" Foreground="#FF554D" VerticalAlignment="Bottom" Margin="6,0,0,6"/>
                            <TextBlock Text="  •  Premium Edition" FontSize="14" Foreground="#C6D0DB" VerticalAlignment="Bottom" Margin="10,0,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Width="44" Height="44" Content="—" Style="{StaticResource GlassButtonStyle}" Click="Minimize_Click"/>
                            <Button Width="44" Height="44" Content="✕" Style="{StaticResource AccentButtonStyle}" Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="310"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,14,0" CornerRadius="20" BorderThickness="1" BorderBrush="#35FFFFFF" Padding="14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#D0181A21" Offset="0"/>
                                <GradientStop Color="#C0101116" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <effects:DropShadowEffect Color="#55000000" BlurRadius="26" ShadowDepth="4" Opacity="0.7"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="НАВИГАЦИЯ" FontSize="13" FontWeight="SemiBold" Foreground="#AAB5C4" Margin="6,4,6,10"/>

                            <StackPanel Grid.Row="1">
                                <Button x:Name="CounterPageBtn" Content="Контрпики" Style="{StaticResource AccentButtonStyle}" Click="GoCounterPage"/>
                                <Button x:Name="MetaPageBtn" Content="Мета" Style="{StaticResource GlassButtonStyle}" Click="GoMetaPage"/>
                                <Button x:Name="ScanBtn" Content="Автоскан" Style="{StaticResource GlassButtonStyle}" Click="StartAutoScan"/>
                                <Button x:Name="RefreshBtn" Content="Обновить мету" Style="{StaticResource GlassButtonStyle}" Click="RefreshMeta"/>
                            </StackPanel>

                            <Border Grid.Row="2" Margin="4,12,4,4" CornerRadius="12" BorderThickness="1" BorderBrush="#2FFFFFFF" Background="#2614171D" Padding="10">
                                <TextBlock Foreground="#AEB7C4" FontSize="12" TextWrapping="Wrap"
                                           Text="Логика кнопок сохранена как раньше. Сейчас изменён только визуал и подача интерфейса."/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="20" BorderThickness="1" BorderBrush="#35FFFFFF" Padding="22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D015171D" Offset="0"/>
                                <GradientStop Color="#CF101217" Offset="0.52"/>
                                <GradientStop Color="#D0151114" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <effects:DropShadowEffect Color="#55000000" BlurRadius="30" ShadowDepth="5" Opacity="0.75"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="PageTitle" Text="Главная панель" FontSize="40" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Margin="0,8,0,0" Foreground="#C7D1DD" FontSize="15"
                                           Text="Современный визуальный слой в стиле premium desktop с плавными акцентами и glow-подсветкой."/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="16" BorderThickness="1" BorderBrush="#44FF746C" Background="#25121419" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Сканирование" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,6,0,0" Text="Визуальный индикатор процесса" Foreground="#B9C3CF"/>
                                        <ProgressBar x:Name="ScanProgress" Margin="0,18,0,0" Height="22" Maximum="100" Value="0"/>
                                        <TextBlock x:Name="StatusText" Margin="0,14,0,0" Foreground="#E1E8F0" Text="Система готова"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="8,0,0,0" CornerRadius="16" BorderThickness="1" BorderBrush="#2FFFFFFF" Background="#1F11161C" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Рекомендации" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#BCC6D2"
                                                   Text="• Контрпики\n• Мета-обновления\n• Готовые точки интеграции backend\n• Smooth UX и аккуратная навигация"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Margin="0,12,0,0" CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF" Background="#1A101317" Padding="10">
                                <TextBlock Foreground="#8FA1B4" FontSize="12"
                                           Text="MetaMind UI • Red/Black/White palette • Design-only update"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="Toast"
                        Width="460"
                        Height="58"
                        CornerRadius="29"
                        Background="#EC141820"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,12,0,0"
                        Opacity="0">
                    <Border.Effect>
                        <effects:DropShadowEffect Color="#88FF3B30" BlurRadius="22" ShadowDepth="0"/>
                    </Border.Effect>
                    <TextBlock x:Name="ToastText"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
