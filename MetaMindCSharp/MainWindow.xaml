<Window x:Class="MetaMind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MetaMind v6.5"
        Width="1360" Height="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="22" Background="#F20C0C0F" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16" Background="#1A1518" BorderBrush="#44FF6B6B" BorderThickness="1" MouseLeftButtonDown="HeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="METAMIND" FontSize="30" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text=" v6.5" FontSize="20" FontWeight="Bold" Foreground="#FF4D4D" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button Width="42" Height="42" Content="—" Click="Minimize_Click"/>
                        <Button Width="42" Height="42" Content="✕" Background="#4A141A" BorderBrush="#FF7A7A" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border CornerRadius="16" Background="#18181C" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="12" Margin="0,0,12,0">
                    <StackPanel>
                        <Button x:Name="CounterPageBtn" Content="Контрпики" Click="GoCounterPage"/>
                        <Button x:Name="MetaPageBtn" Content="Мета" Click="GoMetaPage"/>
                        <Button x:Name="ScanBtn" Content="Автоскан" Click="StartAutoScan"/>
                        <Button x:Name="RefreshBtn" Content="Обновить мету" Click="RefreshMeta"/>
                        <TextBlock Margin="8,20,8,0" Foreground="#B8C0CC" FontSize="12" Text="Здесь оставлены backend-hook'и для CV/GSI/OpenDota." TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="16" Background="#17171A" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PageTitle" Text="Главная панель" FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <Border Grid.Row="1" Margin="0,16,0,0" CornerRadius="14" Background="#121317" BorderBrush="#33FF5C5C" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Полный редизайн на C# WPF, техническая часть может быть подключена без изменения API-логики." Foreground="#D1D7DF" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="ScanProgress" Height="20" Margin="0,16,0,0" Maximum="100" Value="0"/>
                                <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="#FFB0B8C3" Text="Система готова"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="Toast" Width="420" Height="56" CornerRadius="28" Background="#EE15171D" BorderBrush="#55FFFFFF" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0" Opacity="0">
                <TextBlock x:Name="ToastText" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Border>
</Window>
